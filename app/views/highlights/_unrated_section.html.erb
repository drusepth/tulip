<% if @unrated_items.any? %>
  <div class="mb-8">
    <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-coral-light via-white to-lavender-light border-2 border-coral p-6 sm:p-8"
         data-controller="rating-carousel">
      <!-- Decorative sparkles -->
      <div class="absolute -top-4 -right-4 w-24 h-24 opacity-20">
        <svg viewBox="0 0 100 100" fill="currentColor" class="text-coral">
          <path d="M50 5 l5 20 l20 5 l-20 5 l-5 20 l-5 -20 l-20 -5 l20 -5 z"/>
          <path d="M75 60 l3 12 l12 3 l-12 3 l-3 12 l-3 -12 l-12 -3 l12 -3 z" opacity="0.6"/>
        </svg>
      </div>
      <div class="absolute -bottom-2 -left-2 w-16 h-16 opacity-15">
        <svg viewBox="0 0 100 100" fill="currentColor" class="text-lavender-dark">
          <path d="M50 10 l4 16 l16 4 l-16 4 l-4 16 l-4 -16 l-16 -4 l16 -4 z"/>
        </svg>
      </div>

      <!-- Header -->
      <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-3">
          <div class="w-12 h-12 rounded-full bg-coral flex items-center justify-center">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"></path>
            </svg>
          </div>
          <div>
            <h2 class="text-xl font-semibold text-brown">Rate Your Experiences</h2>
            <p class="text-sm text-brown-light"><%= pluralize(@unrated_items.count, "memory") %> waiting for your review</p>
          </div>
        </div>
      </div>

      <!-- Carousel Container -->
      <div class="relative">
        <!-- Navigation Arrows -->
        <button type="button"
                class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-2 sm:-translate-x-4 z-10 w-10 h-10 rounded-full bg-white shadow-cozy flex items-center justify-center text-brown hover:bg-cream transition-colors focus:outline-none cursor-pointer"
                data-rating-carousel-target="prevBtn"
                data-action="click->rating-carousel#prev">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
        </button>

        <button type="button"
                class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-2 sm:translate-x-4 z-10 w-10 h-10 rounded-full bg-white shadow-cozy flex items-center justify-center text-brown hover:bg-cream transition-colors focus:outline-none cursor-pointer"
                data-rating-carousel-target="nextBtn"
                data-action="click->rating-carousel#next">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </button>

        <!-- Slides -->
        <div class="px-6 sm:px-12 overflow-hidden">
          <% @unrated_items.each_with_index do |item, index| %>
            <% photo_url = item.place&.foursquare_photo_url.presence || item.place&.wikidata_image_url.presence %>
            <div class="<%= 'hidden' unless index == 0 %>"
                 data-rating-carousel-target="slide">
              <div class="max-w-lg mx-auto bg-white rounded-2xl overflow-hidden shadow-cozy-lg">
                <!-- Hero Image or Gradient Placeholder -->
                <% if photo_url.present? %>
                  <div class="relative h-48 sm:h-56">
                    <img src="<%= photo_url %>" alt="<%= item.title %>" class="w-full h-full object-cover">
                    <span class="absolute top-3 right-3 px-3 py-1 text-sm rounded-full bg-white text-brown-light capitalize shadow-sm">
                      <%= item.category %>
                    </span>
                  </div>
                <% else %>
                  <div class="relative h-32 sm:h-40 bg-gradient-to-br from-lavender-light via-rose-light to-coral-light flex items-center justify-center">
                    <svg class="w-16 h-16 text-taupe opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    </svg>
                    <span class="absolute top-3 right-3 px-3 py-1 text-sm rounded-full bg-white text-brown-light capitalize shadow-sm">
                      <%= item.category %>
                    </span>
                  </div>
                <% end %>

                <!-- Content -->
                <div class="p-5 sm:p-6">
                  <h3 class="text-xl font-semibold text-brown mb-2"><%= item.title %></h3>

                  <% if item.address.present? %>
                    <p class="text-sm text-brown-light mb-2 flex items-start gap-2">
                      <svg class="w-4 h-4 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                      </svg>
                      <span class="line-clamp-2"><%= item.address %></span>
                    </p>
                  <% end %>

                  <% if item.completed_at.present? %>
                    <p class="text-sm text-brown-light mb-4 flex items-center gap-2">
                      <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                      </svg>
                      <span>Completed <%= item.completed_at.strftime("%b %-d, %Y") %></span>
                    </p>
                  <% end %>

                  <!-- Rating Prompt -->
                  <div class="pt-4 border-t border-taupe-light">
                    <p class="text-center text-brown-light mb-3">How was it?</p>

                    <%= turbo_frame_tag "ratings_#{item.id}" do %>
                      <div class="flex justify-center"
                           data-controller="star-rating"
                           data-star-rating-url-value="<%= stay_bucket_list_item_rating_path(@stay, item) %>"
                           data-star-rating-current-value="0">
                        <div class="flex items-center gap-1">
                          <% (1..5).each do |star_num| %>
                            <button type="button"
                                    class="star-btn p-1 transition-transform hover:scale-110 focus:outline-none cursor-pointer"
                                    data-star-rating-target="star"
                                    data-star-num="<%= star_num %>"
                                    data-action="click->star-rating#rate mouseenter->star-rating#preview mouseleave->star-rating#restore">
                              <svg class="w-10 h-10 text-taupe" data-filled="false" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
                              </svg>
                            </button>
                          <% end %>
                        </div>
                      </div>
                      <p class="text-center text-sm text-taupe italic mt-2" data-star-rating-target="hint">Click to rate</p>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Navigation Dots and Counter -->
      <% if @unrated_items.count > 1 %>
        <div class="mt-6 flex flex-col items-center gap-3">
          <div class="flex items-center gap-2">
            <% @unrated_items.each_with_index do |_, index| %>
              <button type="button"
                      class="w-2.5 h-2.5 rounded-full transition-colors focus:outline-none cursor-pointer <%= index == 0 ? 'bg-coral' : 'bg-taupe-light' %>"
                      data-rating-carousel-target="dot"
                      data-index="<%= index %>"
                      data-action="click->rating-carousel#goToSlide">
              </button>
            <% end %>
          </div>
          <span class="text-sm text-brown-light" data-rating-carousel-target="counter">1 of <%= @unrated_items.count %></span>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

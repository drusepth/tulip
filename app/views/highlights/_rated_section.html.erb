<% if @rated_items.any? %>
  <div class="mb-8">
    <!-- Section Header -->
    <div class="flex items-center gap-3 mb-4">
      <div class="w-8 h-8 rounded-full bg-sage-light flex items-center justify-center">
        <svg class="w-4 h-4 text-sage-dark" fill="currentColor" viewBox="0 0 24 24">
          <path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
        </svg>
      </div>
      <h2 class="text-xl font-semibold text-brown">Rated Experiences</h2>
      <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-taupe-light text-brown-light">
        <%= @rated_items.size %> <%= "memory".pluralize(@rated_items.size) %>
      </span>
    </div>

    <!-- Items Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% @rated_items.each do |item| %>
        <%= render partial: "highlights/item_card", locals: { item: item } %>
      <% end %>
    </div>
  </div>
<% end %>
